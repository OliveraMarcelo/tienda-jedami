# ─────────────────────────────────────────────────────────────────────────────
# .env.prod.example — Plantilla de variables de entorno para producción
#
# Instrucciones:
#   1. Copiar este archivo: cp .env.prod.example .env.prod
#   2. Completar TODOS los valores marcados con TODO
#   3. NUNCA commitear .env.prod al repositorio (está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=jedami
POSTGRES_PASSWORD=TODO_cambia_esta_password_segura
POSTGRES_DB=jedami_prod

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TODO_cambia_esta_password_segura

# ── Backend (jedami-bff) ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_secret_aleatorio_de_64_bytes_minimo
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS — dominio(s) del frontend separados por coma
# Ejemplos: https://jedami.com  o  https://jedami.com,https://www.jedami.com
CORS_ORIGIN=http://TU_IP_O_DOMINIO
FRONTEND_URL=http://TU_IP_O_DOMINIO

# Mercado Pago
MP_PUBLIC_KEY=TODO_tu_mp_public_key_produccion
MP_ACCESS_TOKEN=TODO_tu_mp_access_token_produccion
MP_WEBHOOK_SECRET=TODO_tu_mp_webhook_secret
MP_WEBHOOK_URL=https://TU_DOMINIO/api/v1/payments/webhook

# Rate limiting (valores recomendados para producción)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# Caché Redis TTL en segundos
CACHE_TTL=300
