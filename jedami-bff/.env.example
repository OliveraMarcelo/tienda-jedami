PORT=3000
DATABASE_URL=postgresql://jedami:jedami@localhost:5432/jedami_dev
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
NODE_ENV=development
LOG_LEVEL=info

FRONTEND_URL=http://localhost:5173

# Mercado Pago
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_WEBHOOK_URL=https://tu-ngrok.loca.lt/api/v1/payments/webhook

# Redis (opcional — si no está configurado el caché está desactivado)
